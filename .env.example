# Configurações da DVR Intelbras
DVR_HOST=192.168.0.21
DVR_PORT=80
DVR_USER=manus
DVR_PASS=Teste123
CAMERA_INDEX=2

# Configurações da API de abertura do portão
GATE_API_URL=http://api-v2.pemill.com.br/open/dor/2

# Tempo em segundos que o portão leva para fechar automaticamente
GATE_COOLDOWN_SECONDS=60

# Confiança mínima para a IA considerar uma detecção como válida (0.0 a 1.0)
# Aumentar este valor reduz falsos positivos, mas pode perder detecções legítimas
CONFIDENCE_THRESHOLD=0.5
